# Required secrets
DASHSCOPE_API_KEY=

# Runtime paths
MD5_FILE_PATH=storage/md5/md5.txt
CHAT_HISTORY_DIRECTORY=storage/chat_history
PERSIST_DIRECTORY=storage/chroma_db
COLLECTION_NAME=rag

# Backend / frontend dev server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
VITE_API_PROXY_TARGET=http://localhost:8000

# Retrieval / chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
SEPARATORS=["\n\n", "\n", ".", "!", "?", "。", "！", "？", " ", ""]
MAX_SPLITER_CHAR_NUM=1000
RETRIEVE_TOP_K=10
RETRIEVAL_NEIGHBOR_CHUNKS=2

# Rerank
RERANK_ENABLED=true
RERANK_MODEL_NAME=qwen3-vl-rerank
RERANK_TOP_N=5
RERANK_MIN_DOCS=2
RERANK_FALLBACK_TO_RETRIEVAL=true
RERANK_API_TIMEOUT_SECONDS=10.0

# Models
EMBEDDING_MODEL_NAME=text-embedding-v2
CHAT_MODEL_NAME=qwen3-max

# Query rewrite
REWRITE_ENABLED=true
REWRITE_MODEL_NAME=
REWRITE_HISTORY_TURNS=3
REWRITE_MAX_QUERY_LENGTH=200
REWRITE_FALLBACK_TO_ORIGINAL=true
